{
  "name": "signalrepeater",
  "version": "1.0.0",
  "description": "Bot that take messages from a Discord Server and send them to a Telegram channel/group",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -k -n \"Typescript,Node\" -p \"[{name}]\" -c \"blue,green\" \"tsc --watch\" \"nodemon dist/index.js\" && tslint",
    "lint": "tslint --project tsconfig.json --force",
    "start": "tsc && node dist/app.js"
  },
  "author": "dexbotdev",
  "license": "ISC",
  "dependencies": {
    "@mtproto/core": "^6.2.0",
    "@ptkdev/logger": "^1.8.0",
    "emitter": "^0.0.5",
    "events": "^3.3.0",
    "fetch": "^1.1.0",
    "node-fetch": "^3.3.0",
    "node-telegram-bot-api": "^0.61.0",
    "tsc": "^2.0.4",
    "ws": "^8.12.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.4.0",
    "@types/node": "^18.14.6",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
